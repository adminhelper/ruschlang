# 서버 실행 포트
PORT=3001

# MySQL 연결 정보
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_ROOT_PASSWORD=rusalang_root
MYSQL_USER=rusalang
MYSQL_PASSWORD=rusalang
MYSQL_DATABASE=rusalang
MYSQL_SSL=false

# 관리자 토큰(헤더: x-admin-token)
ADMIN_TOKEN=change-me-admin-token

# CORS 허용 원본
CORS_ORIGIN=http://localhost:3001

# 지도 서비스 설정 (네이버 지도 JS SDK Client ID)
NAVER_MAP_CLIENT_ID=

# 네이버 검색 API (developers.naver.com)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
